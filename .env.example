# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================

# Backend API URL
# For development: http://localhost:5050
# For production: https://your-backend-url.com
VITE_API_URL=http://localhost:5050

# App Version (for cache busting) - Update this when deploying new features
# Format: YYYY.MM.DD.VERSION or use semantic versioning
VITE_APP_VERSION=2025.12.04.1

# Dedicated storefront settings
# Set VITE_STORE_ONLY=true to deploy the public storefront as a standalone app.
# When true, the storefront landing page is served at the root URL.
VITE_STORE_ONLY=false
# Optional dedicated storefront base domain required for share links and admin previews.
# Example: https://your-store-domain.com
VITE_STORE_BASE_URL=https://your-store-domain.com
# Public storefront brand name shown on the storefront landing page.
VITE_STORE_PLATFORM_NAME=DirectData

# =============================================================================
# INSTRUCTIONS
# =============================================================================
# 1. Copy this file to .env
# 2. Update VITE_API_URL with your actual backend URL
# 3. Update VITE_APP_VERSION when deploying new features to force cache refresh
# 4. For production deployment, set VITE_API_URL to your production backend URL
# 5. Never commit .env files to version control